generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  role       String // "admin" | "tecnico" | "parceiro"
  phone      String?
  createdAt  DateTime  @default(now())
  parceiroId String? // só usado quando role === "parceiro": qual Parceiro esse login representa
  parceiro   Parceiro? @relation(fields: [parceiroId], references: [id])

  ordens      OrdemServico[]
  resetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Cliente {
  id             String    @id @default(cuid())
  name           String
  phone          String
  email          String?
  documento      String? // CPF ou CNPJ
  dataNascimento DateTime? // aniversário do cliente
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  uf             String?
  observacoes    String?
  createdAt      DateTime  @default(now())
  ultimoParabensAno Int? // ano em que a mensagem de aniversário automática já foi enviada

  ordens OrdemServico[]
}

model OrdemServico {
  id           String   @id @default(cuid())
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  serviceType  String
  technicianId String?
  technician   User?    @relation(fields: [technicianId], references: [id])
  value        Float?
  scheduledAt  DateTime
  urgent       Boolean  @default(false)
  status       String   @default("aberta") // "aberta" | "andamento" | "concluida" | "recusada"

  // Financeiro
  paymentMethod String? // "dinheiro" | "pix" | "cartao" | "boleto"
  paymentStatus String  @default("pendente") // legado, não usado mais pelo app (ver valorPago)
  valorPago     Float   @default(0) // quanto já foi recebido; pago/parcial/pendente é derivado (lib/paymentStatus.js)
  dueDate       DateTime?

  // Terceirização
  parceiroId         String?
  parceiro           Parceiro? @relation(fields: [parceiroId], references: [id], onDelete: Restrict)
  parceriaTipo       String? // "repassado" (eu recebo comissão) | "recebido" (eu pago comissão)
  parceriaPercentual Float?

  // Materiais e conclusão
  materiais         String?
  assinaturaCliente String? // data URL base64 (PNG) do canvas de assinatura
  avaliacaoNota     Int?    // 1 a 5, opcional

  // Recusa
  motivoRecusa String?
  recusadaEm   DateTime?

  // Automação de WhatsApp (acompanhamento pós-serviço)
  concluidaEm       DateTime? // quando o status virou "concluida" (separado de updatedAt, que muda com qualquer edição)
  followUpEnviadoEm DateTime? // quando a mensagem de acompanhamento (15 dias) foi enviada

  fotos     FotoServico[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model FotoServico {
  id             String       @id @default(cuid())
  ordemServicoId String
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id])
  data           String // data URL base64 (JPEG redimensionado no navegador)
  createdAt      DateTime     @default(now())
}

model Despesa {
  id        String   @id @default(cuid())
  descricao String
  categoria String? // "Material" | "Combustível" | "Manutenção" | "Salário" | "Outro"
  valor     Float
  data      DateTime
  createdAt DateTime @default(now())
}

model Parceiro {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  documento   String?
  observacoes String?
  createdAt   DateTime @default(now())

  ordens OrdemServico[]
  logins User[]
}

model FaixaComissao {
  id         String   @id @default(cuid())
  minValor   Float // fatura a partir desse valor mensal, entra nessa faixa
  percentual Float // % aplicado sobre TODO o faturamento do período
  createdAt  DateTime @default(now())
}
