# PostgreSQL hospedado na Neon (neon.tech) — crie um projeto grátis e copie as
# connection strings no painel ("Connection Details").
#
# DATABASE_URL: connection string POOLED (com "-pooler" no host), usada em
# tempo de execução pela aplicação — necessária porque a Vercel roda várias
# funções serverless simultâneas e o Postgres direto tem limite baixo de
# conexões.
DATABASE_URL="postgresql://usuario:senha@ep-xxxxx-pooler.regiao.aws.neon.tech/neondb?sslmode=require"

# DIRECT_URL: connection string DIRETA (sem "-pooler"), usada só pelo
# `prisma migrate` — o modo transaction do pooler (PgBouncer) não suporta as
# operações que as migrations precisam.
DIRECT_URL="postgresql://usuario:senha@ep-xxxxx.regiao.aws.neon.tech/neondb?sslmode=require"

# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-este-valor-por-um-segredo-aleatorio-em-producao"

# URL pública da aplicação (em produção, a URL do deploy na Vercel/domínio próprio)
NEXTAUTH_URL="http://localhost:3000"

# Resend (resend.com) — usado para enviar o e-mail de "esqueci minha senha".
# Crie uma API Key no painel da Resend.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Sentry (sentry.io) — monitoramento de erros. Copie o DSN no painel do
# projeto ("Configure Next.js SDK" > Copy DSN). Não é um segredo (fica
# exposto no bundle do cliente), mas precisa ser preenchido pra a captura
# de erros funcionar.
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o0.ingest.us.sentry.io/0"
